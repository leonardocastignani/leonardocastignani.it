---
// --- IMPORTS ---
import type { FAQItem } from '../content/config';

// --- PROPS DEFINITION ---
interface Props {
    items: FAQItem[];
    lang?: 'it' | 'en';
    title?: string;
}

// --- INITIAL CONFIGURATION ---
const { items, lang: propLang, title } = Astro.props;

const currentLang = propLang || (Astro.url.pathname.startsWith('/en') ? 'en' : 'it');
const defaultTitle = currentLang === 'en' ? 'Frequently Asked Questions' : 'Domande Frequenti';
const sectionTitle = title || defaultTitle;

// --- JSON-LD SCHEMA CONFIGURATION ---
const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": items.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer
        }
    }))
};
---

{items && items.length > 0 && (
    <div class="faq-section my-12 bg-gray-800/40 border border-gray-700/60 rounded-xl p-6 md:p-8">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-6">{sectionTitle}</h2>
        
        <div class="space-y-4">
            {items.map((item) => (
                <details class="group border-b border-gray-700/50 pb-4 last:border-none last:pb-0">
                    <summary class="flex justify-between items-center font-semibold text-white cursor-pointer list-none [&::-webkit-details-marker]:hidden hover:text-blue-400 transition-colors duration-200 select-none">
                        <span>{item.question}</span>
                        <span class="transition-transform duration-300 group-open:rotate-180 text-gray-400 group-hover:text-blue-400">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                            </svg>
                        </span>
                    </summary>
                    <div class="mt-3 text-gray-300 leading-relaxed prose prose-invert max-w-none prose-a:text-blue-300 hover:prose-a:text-blue-400">
                        <p set:html={item.answer} />
                    </div>
                </details>
            ))}
        </div>
    </div>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
)}