---
// --- IMPORTS ---
import type { GetStaticPaths, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';
import { getI18N, slugifyTag } from '../../../../i18n/utils';
import { SITE_DATA } from '../../../../consts';

// --- STATIC PATHS GENERATION ---
export const getStaticPaths = (async ({ paginate }) => {
    const allPosts = await getCollection('blog', ({ data }) => data.lang === 'it');
    const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    const tagsMap = new Map<string, string>();
    sortedPosts.forEach((post) => {
        post.data.tags?.forEach((tag) => {
            tagsMap.set(slugifyTag(tag), tag);
        });
    });

    return Array.from(tagsMap.keys()).flatMap((sluggedTag) => {
        const originalDisplayTag = tagsMap.get(sluggedTag);
        
        const filteredPosts = sortedPosts.filter((post) => 
            post.data.tags?.some(t => slugifyTag(t) === sluggedTag)
        );

        return paginate(filteredPosts, {
            params: { tag: sluggedTag },
            props: { displayTag: originalDisplayTag },
            pageSize: 6,
        });
    });
}) satisfies GetStaticPaths;


// --- PROPS DEFINITION ---
type Props = {
    page: Page<CollectionEntry<'blog'>>;
};

// --- INITIAL CONFIGURATION ---
const { page } = Astro.props;
const { tag } = Astro.params;
const i18n = getI18N({ astroUrl: Astro.url });

// --- SEO & CANONICAL ---
const pageTitle = `Articoli taggati con "${tag}" ${page.currentPage > 1 ? `- Pagina ${page.currentPage}` : ''} | ${SITE_DATA.name}`;
const description = `Esplora tutti gli articoli del blog riguardanti ${tag}. Leggi guide, tutorial e approfondimenti.`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// --- SCHEMA MARKUP (CollectionPage) ---
const schemaLd = {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": pageTitle,
    "description": description,
    "url": canonicalURL.toString(),
    "isPartOf": {
        "@type": "WebSite",
        "name": SITE_DATA.name,
        "url": SITE_DATA.siteUrl
    }
};
---

<Layout title={pageTitle} description={description}>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(schemaLd)} />

    <main class="pt-24 pb-16 px-4 bg-gray-900 min-h-screen">
        <div class="container mx-auto max-w-4xl">
            {/* INTESTAZIONE PAGINA */}
            <div class="text-center mb-12">
                <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">
                    Tag: <span class="text-blue-400 capitalize">{tag}</span>
                </h1>
                <p class="text-gray-400 text-lg">
                    Pagina {page.currentPage} di {page.lastPage} ({page.total} articoli totali)
                </p>
                <hr class="border-gray-700 my-8" />
            </div>

            {/* GRIGLIA ARTICOLI */}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {page.data.map((post) => {
                    const cleanSlug = post.slug.replace(/^it\//, '');
                    return (
                        <a 
                            href={`/blog/${cleanSlug}/`} 
                            class="block group bg-gray-800 rounded-xl overflow-hidden shadow-lg border border-gray-700 hover:border-blue-400 transition-all duration-300 hover:-translate-y-1"
                        >
                            {post.data.heroImage && (
                                <div class="aspect-[16/9] w-full overflow-hidden border-b border-gray-700 bg-gray-800">
                                    <img 
                                        src={post.data.heroImage} 
                                        alt={post.data.title} 
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" 
                                        loading="lazy"
                                        decoding="async"
                                        width="600"
                                        height="338"
                                    />
                                </div>
                            )}
                            <div class="p-6">
                                <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">
                                    {post.data.title}
                                </h2>
                                <p class="text-gray-400 line-clamp-3 mb-4">{post.data.description}</p>
                                <span class="text-sm text-gray-500 font-mono">
                                    {post.data.pubDate.toLocaleDateString('it-IT', { year: 'numeric', month: 'long', day: 'numeric' })}
                                </span>
                            </div>
                        </a>
                    );
                })}
            </div>

            {/* CONTROLLI PAGINAZIONE */}
            {(page.url.prev || page.url.next) && (
                <div class="flex justify-between items-center mt-12 pt-8 border-t border-gray-700">
                    {page.url.prev ? (
                        <a href={page.url.prev} class="px-6 py-2 bg-gray-800 text-blue-400 font-semibold rounded-lg hover:bg-gray-700 transition-colors">
                            &larr; Precedente
                        </a>
                    ) : <span />}
                    
                    {page.url.next ? (
                        <a href={page.url.next} class="px-6 py-2 bg-gray-800 text-blue-400 font-semibold rounded-lg hover:bg-gray-700 transition-colors">
                            Successiva &rarr;
                        </a>
                    ) : <span />}
                </div>
            )}
        </div>
    </main>
</Layout>