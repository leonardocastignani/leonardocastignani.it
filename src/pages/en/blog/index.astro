---
// --- IMPORTS ---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { getI18N, slugifyTag } from '../../../i18n/utils';
import Maintenance from '../../../components/Maintenance.astro';
import { MAINTENANCE_MODE } from '../../../consts';

// --- INITIAL CONFIGURATION ---
const i18n = getI18N({ astroUrl: Astro.url });

const posts = (await getCollection('blog', ({ data }) => data.lang === 'en')).sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const tagCounts = posts.reduce((acc, post) => {
    post.data.tags?.forEach((tag: string) => {
        const slugged = slugifyTag(tag);
        acc[slugged] = {
            display: tag,
            count: (acc[slugged]?.count || 0) + 1
        };
    });
    return acc;
}, {} as Record<string, { display: string; count: number }>);
const uniqueTags = Object.keys(tagCounts).sort((a, b) => tagCounts[b].count - tagCounts[a].count);
---

{/* MAINTENANCE MODE CHECK */}
{MAINTENANCE_MODE ? (
    <Maintenance lang="en" />
) : (
    <Layout title={`${i18n.blog.title} | Leonardo Castignani`} description={i18n.blog.description}>
        <main class="pt-24 pb-16 px-4 bg-gray-900 min-h-screen">
            <div class="container mx-auto max-w-4xl">
                {/* PAGE TITLE */}
                <h1 class="text-4xl font-bold text-white mb-12 text-center">{i18n.blog.title}</h1>

                {uniqueTags.length > 0 && (
                    <div class="mb-12 p-6 bg-gray-800/30 backdrop-blur-sm border border-gray-800 rounded-2xl shadow-xl">
                        <div class="flex items-center gap-2 mb-4 text-gray-400">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4 text-blue-400">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581a1.43 1.43 0 0 0 2.022 0l4.319-4.319a1.43 1.43 0 0 0 0-2.022L11.16 3.66a2.25 2.25 0 0 0-1.592-.659ZM7.5 9h.008v.008H7.5V9Z" />
                            </svg>
                            <h2 class="text-xs font-semibold uppercase tracking-wider">
                                Filter by topic
                            </h2>
                        </div>
                        
                        <div class="flex flex-wrap gap-2.5">
                            {uniqueTags.map((tag) => (
                                <a
                                    href={`/en/blog/tag/${tag}/`}
                                    class="group flex items-center gap-2 text-xs font-medium px-3.5 py-1.5 bg-gray-950/60 text-gray-300 border border-gray-800/80 rounded-full hover:text-white hover:border-blue-500/50 hover:bg-gray-900 hover:shadow-[0_0_15px_rgba(59,130,246,0.1)] transition-all duration-300 transform hover:-translate-y-0.5"
                                >
                                    <span class="capitalize">{tagCounts[tag].display}</span>
                                    <span class="inline-flex items-center justify-center px-1.5 py-0.5 text-[10px] font-bold font-mono rounded-full bg-gray-900 text-gray-500 group-hover:bg-blue-950 group-hover:text-blue-400 border border-transparent group-hover:border-blue-900/50 transition-colors duration-300">
                                        {tagCounts[tag].count}
                                    </span>
                                </a>
                            ))}
                        </div>
                    </div>
                )}
                
                {/* POSTS GRID */}
                <div class="grid gap-8 md:grid-cols-2">
                    {posts.map((post: CollectionEntry<'blog'>, index: number) => (
                        // POST CARD LINK
                        <a 
                            href={`/en/blog/${post.slug.replace(/^en\//, '')}/`} 
                            class="block group bg-gray-800 rounded-xl overflow-hidden border border-gray-700 hover:border-blue-500 transition-all duration-300 hover:-translate-y-1 shadow-lg"
                        >
                            {post.data.heroImage && (
                                <div class="aspect-[16/9] w-full overflow-hidden border-b border-gray-700 bg-gray-800">
                                    <img 
                                        src={post.data.heroImage} 
                                        alt={post.data.title} 
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                                        loading={index < 2 ? "eager" : "lazy"}
                                        decoding="async"
                                        width="600"
                                        height="335"
                                    />
                                </div>
                            )}
                            <div class="p-6">
                                <div class="text-sm text-blue-400 mb-2">
                                    {post.data.pubDate.toLocaleDateString(i18n.blog.locale, { year: 'numeric', month: 'short', day: 'numeric' })}
                                </div>
                                <h2 class="text-2xl font-bold text-white mb-2 group-hover:text-blue-400 transition-colors">
                                    {post.data.title}
                                </h2>
                                <p class="text-gray-400 line-clamp-3">
                                    {post.data.description}
                                </p>
                                <div class="mt-4 flex gap-2">
                                    {post.data.tags?.map((tag: string) => (
                                        <span class="text-xs bg-gray-900 text-gray-300 px-2 py-1 rounded border border-gray-700">#{tag}</span>
                                    ))}
                                </div>
                            </div>
                        </a>
                    ))}
                </div>
            </div>
        </main>
    </Layout>
)}