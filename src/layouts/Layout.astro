---
// --- IMPORTS ---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { getI18N, getLangFromUrl } from '../i18n/utils';
import { SITE_DATA, SOCIAL_LINKS, MAINTENANCE_MODE } from '../consts';
import '../styles/global.css';

// --- INITIAL CONFIGURATION ---
const currentLang = getLangFromUrl(Astro.url);
const i18n = getI18N({ astroUrl: Astro.url });

const { 
    title = i18n.pageTitle, 
    description = i18n.pageDescription,
    isMaintenance = MAINTENANCE_MODE,
    alternateIt,
    alternateEn,
    image,
    imageAlt = i18n.images.socialAlt
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = image ? new URL(image, Astro.site) : new URL('/social-preview.png', Astro.site);

const currentPath = Astro.url.pathname;
const itPath = currentLang === 'en' ? (currentPath.replace(/^\/en/, '') || '/') : currentPath;
const enPath = currentLang === 'it' ? (`/en${currentPath === '/' ? '/' : currentPath}`) : currentPath;

const hreflangIt = alternateIt || new URL(itPath, Astro.site);
const hreflangEn = alternateEn || new URL(enPath, Astro.site);
---

<!doctype html>
<html lang={currentLang} class="scroll-smooth dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="author" content={SITE_DATA.name} />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="theme-color" content="#111827" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>

        <!-- TAG CANONICAL -->
        <link rel="canonical" href={canonicalURL} />

        <!-- TAG HREFLANG PER SEO INTERNAZIONALE -->
        <link rel="alternate" hreflang="it" href={hreflangIt} />
        <link rel="alternate" hreflang="en" href={hreflangEn} />
        <link rel="alternate" hreflang="x-default" href={hreflangIt} />

        <!-- FAVICON IMPLEMENTATION -->
        <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
        <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/png" sizes="192x192" href="/favicon/web-app-manifest-192x192.png" />
        <link rel="shortcut icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
        <link rel="manifest" href="/favicon/site.webmanifest" />

        <!-- FIX LAYOUT SHIFT -->
        <style is:inline>
            html { scrollbar-gutter: stable; }
        </style>

        <!-- GOOGLE CONSENT MODE DEFAULT -->
        <script type="text/partytown" is:inline>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('consent', 'default', {
                'analytics_storage': 'denied',
                'ad_storage': 'denied',
                'ad_user_data': 'denied',
                'ad_personalization': 'denied'
            });
        </script>

        <!-- GOOGLE TAG MANAGER -->
        <script type="text/partytown" is:inline>
            // @ts-nocheck
            (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
            new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
            j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
            'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
            })(window,document,'script','dataLayer','GTM-M76D882F');
        </script>
        
        <!-- OPEN GRAPH METADATA -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={imageURL} />
        <meta property="og:image:alt" content={imageAlt} />

        <!-- TWITTER CARD METADATA -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={imageURL} />
        <meta name="twitter:image:alt" content={imageAlt} />

        <!-- JSON-LD SCHEMA -->
        <script type="application/ld+json" is:inline set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": ["Person", "ProfessionalService"],
            "name": SITE_DATA.name,
            "url": SITE_DATA.siteUrl,
            "image": {
                "@type": "ImageObject",
                "url": new URL('/profilo.jpg', Astro.site).toString(),
                "description": i18n.images.profileAlt
            },
            "jobTitle": SITE_DATA.jobTitle,
            "areaServed": {
                "@type": "GeoCircle",
                "geoMidpoint": {
                    "@type": "GeoCoordinates",
                    "latitude": "43.30675",
                    "longitude": "13.72860"
                },
                "geoRadius": "50000"
            },
            "address": {
                "@type": "PostalAddress",
                "addressLocality": "Civitanova Marche",
                "addressRegion": "Marche",
                "addressCountry": "IT"
            },
            "sameAs": [
                SOCIAL_LINKS.linkedin,
                SOCIAL_LINKS.github
            ],
            "email": SITE_DATA.email,
            "knowsAbout": ["Java", "JavaScript", "TypeScript", "Astro", "Tailwind CSS", "SQL", "Web Development"]
        })} />
    </head>
    <body class="bg-gray-900 text-gray-100 font-sans overflow-x-hidden">
        <!-- HEADER -->
        <Header isMaintenance={isMaintenance} />

        <!-- MAIN CONTENT -->
        <main id="main-content">
            <slot />
        </main>

        <!-- FOOTER -->
        <Footer />

        <!-- COOKIE CONSENT BANNER -->
        <CookieConsent />

        <!-- BACK TO TOP BUTTON -->
        <a
            id="back-to-top-btn"
            href="#"
            aria-label={i18n.backToTopLabel}
            class="fixed bottom-8 right-8 bg-blue-600 hover:bg-blue-500 text-white w-12 h-12 rounded-full flex items-center justify-center shadow-lg transition-all duration-300 opacity-0 z-50 translate-y-10"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
            </svg>
        </a>

        <div class="fixed bottom-6 left-6 z-90 flex flex-col items-center gap-3">
            
            <!-- COOKIE PREFERENCES BUTTON -->
            <button
                id="cookie-preferences-btn"
                aria-label="Gestisci preferenze cookie"
                title="Gestisci preferenze cookie"
                class="relative w-8 h-8 p-0 rounded-full bg-gray-700/80 hover:bg-gray-600 border border-gray-500/50 backdrop-blur-sm shadow-md transition-all duration-200 hover:scale-110 opacity-0"
            >
                <svg class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-5 h-5" viewBox="1 1 54 66" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M28 3 L53 12 L53 33 C53 48 41 58 28 65 C15 58 3 48 3 33 L3 12 Z" fill="#1E3A5F" stroke="#3B82F6" stroke-width="1.8"/>
                    <rect x="19" y="34" width="18" height="14" rx="3" fill="#60A5FA"/>
                    <path d="M22 34 L22 28 C22 23 34 23 34 28 L34 34" fill="none" stroke="#93C5FD" stroke-width="2.2" stroke-linecap="round"/>
                    <circle cx="28" cy="40" r="2.5" fill="#1E3A5F"/>
                    <rect x="27" y="41" width="2" height="4" rx="1" fill="#1E3A5F"/>
                </svg>
            </button>

            <!-- WHATSAPP CONTACT BUTTON -->
            <div class="flex items-center justify-start group relative">
                <div class="absolute left-[110%] opacity-0 group-hover:opacity-100 group-active:opacity-100 focus-within:opacity-100 -translate-x-4 group-hover:translate-x-0 group-active:translate-x-0 focus-within:translate-x-0 transition-all duration-300 ease-out pointer-events-none">
                    <div class="bg-white/80 backdrop-blur-md text-[#1D1D1F] text-xs font-semibold py-2 px-4 rounded-full shadow-[0_8px_30px_rgba(0,0,0,0.08)] border border-white/50 whitespace-nowrap flex items-center gap-2">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#34C759] opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#34C759]"></span>
                        </span>
                        {i18n.whatsapp.tooltip}
                    </div>
                </div>

                <a 
                    href={`https://api.whatsapp.com/send?phone=${SITE_DATA.whatsappNumber}&text=${i18n.whatsapp.message}`} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="bg-[#34C759] hover:bg-[#30D158] text-white p-2.5 rounded-full shadow-[0_6px_20px_rgba(52,199,89,0.3)] hover:shadow-[0_6px_20px_rgba(52,199,89,0.5)] transition-all duration-300 hover:scale-105 active:scale-95 flex items-center justify-center relative z-10 outline-none"
                    aria-label={i18n.whatsapp.ariaLabel}
                >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                    </svg>
                </a>
            </div>

        </div>
                    
        <!-- GLOBAL SCRIPTS INITIALIZATION -->
        <script>
            import { initFadeInAnimations } from '../scripts/animations.js';
            import { initBackToTop } from '../scripts/backToTop.js';

            function initGlobalScripts() {
                try {
                    initFadeInAnimations();
                } catch (e) {
                    console.error("Errore animazioni:", e);
                }

                try {
                    initBackToTop();
                } catch (e) {
                    console.error("Errore BackToTop:", e);
                }
            }

            document.addEventListener('astro:page-load', initGlobalScripts);

            if (document.readyState !== 'loading') {
                initGlobalScripts();
            } else {
                document.addEventListener('DOMContentLoaded', initGlobalScripts);
            }

            window.addEventListener('unhandledrejection', (event) => {
                if (event.reason && event.reason.name === 'InvalidStateError') {
                    event.preventDefault();
                }
            });
        </script>

        <!-- COOKIE PREFERENCES BUTTON SCRIPT -->
        <script>
            import { initCookiePreferencesBtn } from '../scripts/cookiePreferencesBtn.js';

            document.addEventListener('astro:page-load', initCookiePreferencesBtn);
            if (document.readyState !== 'loading') {
                initCookiePreferencesBtn();
            } else {
                document.addEventListener('DOMContentLoaded', initCookiePreferencesBtn);
            }
        </script>

        <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M76D882F"
        height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    </body>
</html>