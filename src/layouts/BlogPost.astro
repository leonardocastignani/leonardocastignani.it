---
// --- IMPORTS ---
import type { CollectionEntry } from 'astro:content';
import Layout from './Layout.astro';
import { getI18N, slugifyTag } from '../i18n/utils';
import Maintenance from '../components/Maintenance.astro';
import FAQ from '../components/FAQ.astro';
import AuthorBox from '../components/AuthorBox.astro';
import { MAINTENANCE_MODE, SITE_DATA } from '../consts';

// --- PROPS DEFINITION ---
type Props = CollectionEntry<'blog'>['data'];

// --- INITIAL CONFIGURATION ---
const { title, description, pubDate, updatedDate, heroImage, imageAlt, imageTitle, imageCaption, lang, alternateSlug, faqs, tags } = Astro.props;
const i18n = getI18N({ astroUrl: Astro.url });

const backLink = lang === 'en' ? '/en/blog' : '/blog';

let alternateIt = undefined;
let alternateEn = undefined;

if (alternateSlug) {
    if (lang === 'it') {
        alternateEn = new URL(`/en/blog/${alternateSlug}/`, Astro.site);
    } else {
        alternateIt = new URL(`/blog/${alternateSlug}/`, Astro.site);
    }
}

// --- JSON-LD SCHEMA CONFIGURATION ---
const defaultImage = new URL('/social-preview.png', Astro.site).toString();
const finalImage = heroImage ? new URL(heroImage, Astro.site).toString() : defaultImage;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  },
  "headline": title,
  "description": description,
  "image": {
    "@type": "ImageObject",
    "url": finalImage,
    "description": imageAlt || description,
    "caption": imageCaption || title
  },
  "author": {
    "@type": "Person",
    "name": SITE_DATA.name,
    "url": SITE_DATA.siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": SITE_DATA.name,
    "logo": {
      "@type": "ImageObject",
      "url": new URL('/favicon/favicon-96x96.png', Astro.site).toString()
    }
  },
  "datePublished": pubDate.toISOString(),
  "dateModified": updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  "inLanguage": lang === 'it' ? 'it-IT' : 'en-US'
};
---

{/* MAINTENANCE MODE CHECK */}
{MAINTENANCE_MODE ? (
    <Maintenance lang={lang} />
) : (
    <Layout title={title} description={description} image={heroImage} imageAlt={imageAlt || title} alternateIt={alternateIt} alternateEn={alternateEn}>
        
        <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
        
        <main class="pt-24 pb-16 px-4 bg-gray-900 min-h-screen">
            <article class="container mx-auto max-w-3xl">
                {/* HERO IMAGE */}
                {heroImage && (
                    <figure class="mb-8 w-full">
                        <div class="rounded-xl overflow-hidden shadow-2xl aspect-[16/9] w-full bg-gray-800">
                            <img 
                                src={heroImage} 
                                alt={imageAlt || title} 
                                title={imageTitle}
                                class="w-full h-full object-cover"
                                loading="eager" 
                                decoding="async"
                                width="1200"
                                height="669"
                            />
                        </div>
                        {imageCaption && (
                            <figcaption class="text-center mt-3 text-sm text-gray-400 italic">
                                {imageCaption}
                            </figcaption>
                        )}
                    </figure>
                )}

                {/* POST HEADER */}
                <div class="mb-8 text-center">
                    <div class="text-gray-400 mb-2">
                        <time datetime={pubDate.toISOString()}>
                            {pubDate.toLocaleDateString(i18n.blog.locale, {
                                year: 'numeric',
                                month: 'long',
                                day: 'numeric',
                            })}
                        </time>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4">{title}</h1>

                    {tags && tags.length > 0 && (
                        <div class="flex flex-wrap justify-center gap-2 mt-4">
                            {tags.map((tag) => (
                                <a 
                                    href={lang === 'en' ? `/en/blog/tag/${slugifyTag(tag)}/` : `/blog/tag/${slugifyTag(tag)}/`}
                                    class="text-xs font-mono px-3 py-1 bg-gray-800 text-blue-400 border border-gray-700 rounded-full hover:bg-gray-700 hover:border-blue-400 transition-colors duration-200"
                                >
                                    #{tag}
                                </a>
                            ))}
                        </div>
                    )}

                    <hr class="border-gray-700 my-8" />
                </div>
                
                {/* POST CONTENT (Markdown) */}
                <div class="prose prose-invert prose-lg max-w-none hover:prose-a:text-blue-400 prose-a:text-blue-300 prose-headings:text-white prose-p:text-gray-300 prose-strong:text-white prose-code:text-blue-300">
                    <slot />
                </div>

                {/* POST AUTHOR */}
                <AuthorBox lang={lang} />

                {/* POST FAQS */}
                {faqs && faqs.length > 0 && <FAQ items={faqs} lang={lang} />}
            </article>
            
            {/* POST FOOTER */}
            <div class="text-center mt-12">
                <a href={backLink} class="text-blue-400 hover:text-blue-300 font-semibold">
                    {i18n.blog.backToArticles}
                </a>
            </div>
        </main>
    </Layout>
)}